FROM mariadb:11
# DB credentials injected via --env-file at runtime.
# MariaDB reads: MYSQL_DATABASE, MYSQL_USER, MYSQL_PASSWORD, MYSQL_ROOT_PASSWORD
# The .env uses DB_* names, so the post-deploy maps them.

COPY shared/tainer-db-entrypoint.sh /usr/local/bin/tainer-db-entrypoint.sh
RUN chmod +x /usr/local/bin/tainer-db-entrypoint.sh

ENTRYPOINT ["tainer-db-entrypoint.sh"]
CMD ["mariadbd"]
