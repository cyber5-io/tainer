#!/bin/bash

set -e

echo "/opt/tainer/bin" > /etc/paths.d/00-tainer

# krunkit has a hardcoded rpath to /opt/podman/lib that can't be patched.
# Symlink so it finds dylibs at /opt/tainer/lib.
if [ ! -e /opt/podman/lib ]; then
    mkdir -p /opt/podman
    ln -sf /opt/tainer/lib /opt/podman/lib
fi

# make sure to ignore errors, this is not a hard requirement to use tainer
/opt/tainer/bin/tainer-mac-helper install || :

# Add pointer to tainer docs in manpath
mkdir -p /usr/local/etc/man.d/
echo "MANPATH /opt/tainer/docs/man" > /usr/local/etc/man.d/tainer.man.conf

# Set up offline DNS resolver for *.tainer.me domains.
# Routes DNS queries to the local dnsmasq container via port 7753.
mkdir -p /etc/resolver
cat > /etc/resolver/tainer.me <<'RESOLVER'
nameserver 127.0.0.1
port 7753
RESOLVER

# Set up pf firewall redirect: port 22 -> 2222 on loopback.
# Podman's gvproxy can't bind privileged ports on macOS, so we use pf to
# let users SSH on the standard port 22.
PF_ANCHOR="/etc/pf.anchors/tainer"
PF_CONF="/etc/pf.conf"

cat > "$PF_ANCHOR" <<'PFANCHOR'
rdr pass on lo0 inet proto tcp from any to 127.0.0.1 port 22 -> 127.0.0.1 port 2222
PFANCHOR

if ! grep -q 'anchor "tainer"' "$PF_CONF" 2>/dev/null; then
    # Backup original pf.conf before modifying
    cp "$PF_CONF" "${PF_CONF}.tainer-backup"

    # Insert rdr-anchor before the existing dummynet-anchor (or at end of anchors)
    if grep -q 'dummynet-anchor' "$PF_CONF"; then
        sed -i '' '/dummynet-anchor/i\
rdr-anchor "tainer"
' "$PF_CONF"
    else
        echo 'rdr-anchor "tainer"' >> "$PF_CONF"
    fi

    # Append load anchor at the end
    echo 'load anchor "tainer" from "/etc/pf.anchors/tainer"' >> "$PF_CONF"
fi

pfctl -f "$PF_CONF" 2>/dev/null || :

# Set up user config directory.
REAL_USER=$(stat -f '%Su' /dev/console)
if [ -n "$REAL_USER" ] && [ "$REAL_USER" != "root" ]; then
    REAL_HOME=$(dscl . -read "/Users/$REAL_USER" NFSHomeDirectory | awk '{print $2}')

    # Install TLS wildcard cert for *.tainer.me
    CERTS_DIR="$REAL_HOME/.config/tainer/certs"
    mkdir -p "$CERTS_DIR"
    cp /opt/tainer/certs/tainer.me.crt "$CERTS_DIR/"
    cp /opt/tainer/certs/tainer.me.key "$CERTS_DIR/"
    chmod 644 "$CERTS_DIR/tainer.me.crt"
    chmod 600 "$CERTS_DIR/tainer.me.key"

    # Generate SSH keys for sshpiper and project containers.
    KEYS_DIR="$REAL_HOME/.config/tainer/keys"
    mkdir -p "$KEYS_DIR"
    if [ ! -f "$KEYS_DIR/tainer_rsa" ]; then
        ssh-keygen -t rsa -b 4096 -f "$KEYS_DIR/tainer_rsa" -N "" -q
    fi
    if [ ! -f "$KEYS_DIR/sshpiper_host_ed25519" ]; then
        ssh-keygen -t ed25519 -f "$KEYS_DIR/sshpiper_host_ed25519" -N "" -q
    fi
    # sshpiper runs as non-root inside the container and needs to read the host key
    chmod 644 "$KEYS_DIR/sshpiper_host_ed25519"

    chown -R "$REAL_USER" "$REAL_HOME/.config/tainer"

    # Initialize the Tainer machine with 1/4 of system memory.
    # Other users get auto-initialized on first tainer command.
    MEM_BYTES=$(sysctl -n hw.memsize)
    MEM_MB=$(( MEM_BYTES / 1024 / 1024 / 4 ))
    # Floor at 4096 MB minimum for Next.js dev workloads
    if [ "$MEM_MB" -lt 4096 ]; then
        MEM_MB=4096
    fi

    sudo -u "$REAL_USER" /opt/tainer/bin/tainer machine init --memory "$MEM_MB" || :
    sudo -u "$REAL_USER" /opt/tainer/bin/tainer machine set --rootful || :
    sudo -u "$REAL_USER" /opt/tainer/bin/tainer machine start || :
fi
