<?xml version="1.0" encoding="utf-8" standalone="no"?>
<installer-script minSpecVersion="1.000000">
    <title>Tainer __VERSION__</title>
    <background mime-type="image/svg+xml" file="banner.svg" scaling="proportional"/>
    <background-darkAqua mime-type="image/svg+xml" file="banner-darkAqua.svg" scaling="proportional"/>
    <welcome file="welcome.html" mime-type="text/html" />
    <conclusion file="conclusion.html" mime-type="text/html" />
    <license file="LICENSE.txt"/>
    <options customize="never" hostArchitectures="x86_64,arm64" />
    <domains enable_localSystem="true" />
    <choices-outline>
        <line choice="tainer"/>
    </choices-outline>
    <choice id="tainer" title="tainer">
        <pkg-ref id="tainer.pkg"/>
    </choice>
    <pkg-ref id="tainer.pkg">tainer.pkg</pkg-ref>
</installer-script>
